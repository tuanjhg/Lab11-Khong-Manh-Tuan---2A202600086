    "    runner=protected_runner,\n",
    "    nemo_rails=nemo_rails if 'nemo_rails' in dir() and nemo_rails else None\n",
    ")\n",
    "\n",
    "await pipeline.run_suite(standard_attacks)\n",
    "print(pipeline.generate_report())"
