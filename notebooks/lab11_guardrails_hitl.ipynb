        "\n",
        "sample_conversation: |\n",
        "  user \"Hi, what is the interest rate for savings?\"\n",
        "    express greeting and ask about savings\n",
        "  bot express greeting and provide savings info\n",
        "    \"Hello! Our current savings interest rate is 5.5% per year for 12-month term deposits.\"\n",
        "\n",
        "prompt_templates:\n",
        "  self_check_input:\n",
        "    content: |\n",
        "      Is the user message asking about account inquiries, transactions, banking questions, or something else?\n",
        "      If it is related to banking, say 'banking'. Otherwise, say 'other'.\n",
        "  self_check_output:\n",
        "    content: |\n",
        "      Is the following bot response safe and appropriate for a banking customer?\n",
        "      Does it leak any sensitive information (passwords, API keys, database details)?\n",
