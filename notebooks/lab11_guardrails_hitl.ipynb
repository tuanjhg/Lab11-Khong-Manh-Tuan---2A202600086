    "# 1. Each `define flow <name>` MUST have a UNIQUE name (no duplicates!).\n",
    "# 2. Keep quoted strings ASCII-clean \u2014 avoid apostrophes and diacritics in quotes.\n",
    "# 3. Pattern per attack class:\n",
    "#       define user <category>\n",
