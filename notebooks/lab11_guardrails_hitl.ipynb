    "        \"\"\"NeMo generate_async return type varies. Handle dict / str / obj uniformly.\"\"\"\n",
    "        if isinstance(result, dict):\n",
    "            return result.get(\"content\", str(result))\n",
    "        if hasattr(result, \"content\"):\n",
    "            return result.content\n",
    "        return str(result)\n",
